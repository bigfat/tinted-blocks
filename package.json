{
	"name": "tinted-blocks",
	"version": "0.5.0",
	"description": "Tinted Blocks: add background color to blocks in Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"highlight",
		"blocks",
		"color",
		"markdown"
	],
	"license": "UNLICENSED",
	"devDependencies": {
		"@codemirror/language": "^6.12.2",
		"@eslint/js": "9.30.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.56.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
